# Server Configuration
PORT=3032
HOSTNAME=localhost
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Authentication
FEATHERS_SECRET=generate-a-secure-secret-here

# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=lumina_db
MYSQL_SSL=false

# External Services (Google OAuth - Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=https://your-vercel-domain.com/dashboard
OAUTH_ORIGINS=https://your-vercel-domain.com

# Auto Collection Reminders Logic
AUTO_COLLECTION_REMINDERS_ENABLED=false
AUTO_COLLECTION_REMINDERS_INTERVAL_MINUTES=60
AUTO_COLLECTION_REMINDERS_COOLDOWN_HOURS=24
AUTO_COLLECTION_REMINDERS_RUN_ON_STARTUP=false
AUTO_COLLECTION_REMINDERS_OVERDUE_ONLY=true
AUTO_COLLECTION_REMINDERS_TIMEZONE=Asia/Kolkata
AUTO_COLLECTION_REMINDERS_DAILY_HOUR=9
AUTO_COLLECTION_REMINDERS_DAILY_MINUTE=0
AUTO_COLLECTION_REMINDERS_STAGE_DAYS=1,3,7
